@model IEnumerable<NorthwindApp.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<h1 class="mb-4">Categories</h1>

<div class="row g-4">
    @foreach (var cat in Model)
    {
        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">@cat.Name</h5>
                    <p class="card-text text-muted small">@cat.Description</p>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                    <span class="text-muted small">@cat.Products.Count products</span>
                    <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@cat.Id"
                       class="btn btn-sm btn-outline-primary">View</a>
                </div>
            </div>
        </div>
    }
</div>
